{
"deploy": {
    "numReplicas": 1,
    "startCommand": "php artisan serve --host=0.0.0.0 --port=8000",
    "build": {
      "commands": [
        "mkdir -p resources/views",
        "echo 'Dummy view' > resources/views/welcome.blade.php",
        "php artisan config:cache",
        "php artisan event:cache",
        "php artisan route:cache"
      ]
    }
  }
}
